      "replacement": "quantagent.cli.v8_deep and trusted evaluator",
      "removal_after": "2026-10-01"
    },
    {
      "module": "quantagent.cli.v8_gated",
      "category": "legacy_experiment",
      "replacement": "pre-registered research runner",
      "removal_after": "2026-10-01"
    },
    {
      "module": "quantagent.cli.v8_portfolio",
      "category": "legacy_portfolio",
      "replacement": "quantagent.portfolio.pareto_allocator",
      "removal_after": "2026-10-01"
    },
    {
