{
  "schema_version": 1,
  "default_enabled": false,
  "enable_environment_variable": "QUANTAGENT_ENABLE_LEGACY_CLI",
  "modules": [
    {
      "module": "quantagent.cli.v7_research",
      "category": "legacy_research",
      "replacement": "governed factor registry and research workflows",
      "removal_after": "2026-10-01"
    },
    {
