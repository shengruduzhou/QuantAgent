# LLM providers. Keep real keys in .env, never commit them or print them in logs.
OPENAI_API_KEY=
GOOGLE_API_KEY=
QUANTAGENT_LLM_PROVIDER=disabled
QUANTAGENT_LLM_ENABLED=false
QUANTAGENT_LLM_ALLOW_NETWORK=false
QUANTAGENT_LLM_ENDPOINT=https://api.openai.com/v1/responses
QUANTAGENT_LLM_MODEL=gpt-4.1-mini
QUANTAGENT_LLM_API_KEY_ENV=OPENAI_API_KEY
QUANTAGENT_LLM_TIMEOUT_SECONDS=30
QUANTAGENT_LLM_MAX_INPUT_CHARS=16000
QUANTAGENT_LLM_RESPONSE_FORMAT=json_object
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

# Gemini / Gemma through Google AI Studio. Keep the real key local only.
# GOOGLE_API_KEY=<local-only>
# QUANTAGENT_LLM_PROVIDER=gemini
# QUANTAGENT_LLM_ENABLED=true
# QUANTAGENT_LLM_ALLOW_NETWORK=true
# QUANTAGENT_LLM_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
# QUANTAGENT_LLM_MODEL=<google-ai-studio-model-id>
# QUANTAGENT_LLM_API_KEY_ENV=GOOGLE_API_KEY

# Market / fundamentals / news data providers.
ALPHA_VANTAGE_API_KEY=
FINANCIAL_DATASETS_API_KEY=
POLYGON_API_KEY=
FMP_API_KEY=

# Execution adapters should stay disabled until paper trading is validated.
BROKER_MODE=paper
IBKR_HOST=
IBKR_PORT=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
